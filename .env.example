# Web (Vite)
VITE_API_BASE_URL=http://localhost:8080
VITE_CHAT_API_BASE_URL=http://127.0.0.1:8002

# Mobile (Expo Go) — use your PC LAN IP so the phone can reach the API
# Example: ipconfig → IPv4 Address 192.168.1.42
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.42:8080
EXPO_PUBLIC_CHAT_API_BASE_URL=http://192.168.1.42:8002

# true = demo data only (work on UI without Docker/backend)
# On mobile, mock is ON by default unless set to false
VITE_USE_MOCK_API=true
EXPO_PUBLIC_USE_MOCK_API=true
